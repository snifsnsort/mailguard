# MailGuard — Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ── Auth ──────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars
ADMIN_PASSWORD=changeme

# ── Microsoft 365 Tenant (primary) ───────────────────────────────────────────
# See docs/M365_SETUP.md for how to create these
SEED_TENANT_DOMAIN=yourdomain.com
SEED_TENANT_ID=00000000-0000-0000-0000-000000000000
SEED_CLIENT_ID=00000000-0000-0000-0000-000000000000
SEED_CLIENT_SECRET=your-client-secret-here

# ── Google Workspace OAuth ────────────────────────────────────────────────────
# See docs/GWS_SETUP.md for how to create these
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/google/callback

# ── Database ──────────────────────────────────────────────────────────────────
# Leave blank for default (/tmp/mailguard.db in production, ./mailguard.db locally)
DATABASE_URL=sqlite:///./mailguard.db

# ── Encryption ───────────────────────────────────────────────────────────────
# Leave blank — auto-derived from SECRET_KEY (deterministic, survives restarts)
ENCRYPTION_KEY=

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8000

# ── Feature Flags ────────────────────────────────────────────────────────────
# Set to "true" to manage multiple M365 tenants
MULTI_TENANT_MODE=false
DEBUG=true

# MailGuard — Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ── Auth ──────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars
ADMIN_PASSWORD=changeme

# ── Microsoft 365 Tenant ──────────────────────────────────────────────────────
# Option A — Self-hosted (recommended): seed a tenant automatically on boot.
# Create an App Registration in your Azure AD with app-only permissions.
# See docs/M365_SETUP.md for the exact permissions needed.
SEED_TENANT_DOMAIN=yourdomain.com
SEED_TENANT_ID=00000000-0000-0000-0000-000000000000
SEED_CLIENT_ID=00000000-0000-0000-0000-000000000000
SEED_CLIENT_SECRET=your-client-secret-here

# Option B — OAuth "Connect M365" button (SaaS / multi-tenant deployments only).
# Requires a SEPARATE multi-tenant Azure App Registration for MailGuard itself
# (different from the per-tenant App Registration used in Option A).
# Leave blank when using Option A or the manual form — the button will show a
# clear error message if these are not set, which is expected for self-hosted use.
MAILGUARD_CLIENT_ID=
MAILGUARD_CLIENT_SECRET=
MAILGUARD_REDIRECT_URI=http://localhost:8000/api/auth/callback

# ── Google Workspace OAuth ────────────────────────────────────────────────────
# Required to use the "Connect Google" button on the Connect page.
# Create an OAuth 2.0 Client ID in Google Cloud Console (Web application type).
# Set the Authorized redirect URI to match GOOGLE_REDIRECT_URI exactly.
# See docs/GWS_SETUP.md for step-by-step instructions.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/google/callback

# ── Advanced (optional) ───────────────────────────────────────────────────────
# ENCRYPTION_KEY=          # leave blank — auto-derived from SECRET_KEY
# DATABASE_URL=sqlite:////tmp/mailguard.db
# ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8000
# MULTI_TENANT_MODE=false

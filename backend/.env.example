# ============================================================
# MailGuard — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# Run setup.ps1 (Windows) or setup.sh (Linux/Mac) to do this
# automatically and generate a secure SECRET_KEY.
# NEVER commit .env to git.
# ============================================================

# ── REQUIRED ─────────────────────────────────────────────────
# Generate a secure key with: openssl rand -hex 32
SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars
ADMIN_PASSWORD=changeme

# ── MICROSOFT 365 ────────────────────────────────────────────
# Create an App Registration in your Azure AD tenant.
# See docs/M365_SETUP.md for exact steps and required permissions.
#
# These seed a tenant automatically on every container start.
# Use the manual form on the Connect page as an alternative.
SEED_TENANT_NAME=My Organization
SEED_TENANT_DOMAIN=yourdomain.com
SEED_TENANT_ID=00000000-0000-0000-0000-000000000000
SEED_CLIENT_ID=00000000-0000-0000-0000-000000000000
SEED_CLIENT_SECRET=your-client-secret-here

# ── GOOGLE WORKSPACE ─────────────────────────────────────────
# Create an OAuth 2.0 Client ID in Google Cloud Console.
# Type: Web application
# Authorized redirect URI: http://localhost:8000/api/v1/google/callback
#   (add your production URL too if deploying to Azure/cloud)
# See docs/GWS_SETUP.md for exact steps.
#
# Accepts either GWS_* or GOOGLE_* prefix — use whichever you prefer.
GWS_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GWS_CLIENT_SECRET=your-google-client-secret
GWS_REDIRECT_URI=http://localhost:8000/api/v1/google/callback

# ── OPTIONAL ──────────────────────────────────────────────────
# DATABASE_URL=sqlite:////tmp/mailguard.db
# ENCRYPTION_KEY=        # auto-derived from SECRET_KEY if blank
# ALLOWED_ORIGINS=http://localhost:8000,http://localhost:5173
# MULTI_TENANT_MODE=false
# FRONTEND_URL=http://localhost:8000
